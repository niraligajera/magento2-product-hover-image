{
    "name": "niraligajera/module-rollover-image-all-places",
    "description": "Magento 2 Hyva compatible module to display alternate product image on hover with lazy loading and fallback support.",
    "type": "magento2-module",
    "license": [
        "OSL-3.0",
        "AFL-3.0"
    ],
    "require": {
        "php": "~7.4.0||~8.1.0||~8.2.0||~8.3.0||~8.4.0",
        "magento/framework": "*",
        "magento/module-catalog": "*",
        "magento/module-config": "*"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Ethnic\\RollOverImage\\": ""
        }
    },
    "extra": {
        "map": [
            ["*", "Ethnic/RollOverImage"]
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}